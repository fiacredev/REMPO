{
  "name": "git-helper",
  "displayName": "git-helper-rempo",
  "description": "Remember what you were building.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": ["Other"],
  "activationEvents": ["*"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "git-helper.refresh",
        "title": "Refresh"
      },
      {
        "command": "git-helper.commit",
        "title": "Commit Changes"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "git-helper",
          "title": "REMPO",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "git-helper": [
        {
          "id": "git-helper-view",
          "name": " Remember Mellow"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "git-helper.refresh",
          "when": "view == git-helper-view",
          "group": "navigation"
        },
        {
          "command": "git-helper.commit",
          "when": "view == git-helper-view",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "check-types": "tsc --noEmit",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/node": "22.x",
    "typescript": "^5.9.3",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5"
  }
}